# GraphMind AI — Environment Variables
# Copy to .env and fill in your values

# Groq API key (free — https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Model — llama-3.3-70b-versatile (default), llama-4-scout-17b-16e-instruct, qwen-qwq-32b
GROQ_MODEL=llama-3.3-70b-versatile

# Groq API endpoint (default)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# CORS origins for frontend (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend env (set in Vercel dashboard) ──
# VITE_API_URL=https://your-render-app.onrender.com
